{
  "name": "ts-presentation-playground",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Interactive Web-Based TypeScript Presentation Playground with live Monaco diagnostics.",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "generate": "nuxt generate",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,vue,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,vue,js,json,md}\"",
    "typecheck": "nuxt typecheck",
    "check:samples": "tsx scripts/check-samples.ts",
    "demo:tools": "tsx samples/01-kickstart-setup/tools-demo.ts",
    "demo:targets": "tsx samples/02-build-process/compile-targets.ts"
  },
  "dependencies": {
    "monaco-editor": "^0.52.0",
    "nuxt": "^3.14.0",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.31.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vue-tsc": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
